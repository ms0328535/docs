  "keyFeatures": [
    "Patient registration, lookup, and deletion via a singly linked list",
    "Doctor registry using a binary search tree (BST) for efficient lookups",
    "FIFO appointment request queue (circular array) for fair scheduling",
    "LIFO undo stack to reverse the most recently scheduled appointment",
    "Menu-driven console interface with a single-file C implementation"
  ],
  "publicApiSurface": [
